generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String           @id @default(uuid())
  name         String
  email        String           @unique
  phone        String?
  password     String?
  resume       String?
  image        String?
  applications JobApplication[]
  profile      UserProfile?
}

model Admin {
  id           String           @id @default(uuid())
  name         String
  email        String           @unique
  password     String
  role         String           @default("admin")
  createdAt    DateTime         @default(now())
  jobs         Job[]
  applications JobApplication[] @relation("AdminReviewer")
}

model Company {
  id                String           @id @default(uuid())
  name              String           @unique
  email             String
  phone             String
  image             String
  password          String
  isVerified        Boolean          @default(false)
  havePremiumAccess Boolean          @default(false)
  jobs              Job[]
  applications      JobApplication[]
}

model Job {
  id              String           @id @default(uuid())
  title           String
  description     String
  location        String
  category        String
  deadline        DateTime
  level           String
  experience      Int
  salary          Int
  openings        Int
  date            DateTime
  visible         Boolean          @default(true)
  requirements    Json?
  employmentType  String
  qualification   String?
  companyId       String
  createdBy       String?
  companyDetails  Json
  isVerified      Boolean          @default(false)
  isViewApplicant Boolean          @default(false)
  objections      Json?
  objectionsTrack Json?
  isEdited        Boolean          @default(false)
  company         Company          @relation(fields: [companyId], references: [id])
  admin           Admin?           @relation(fields: [createdBy], references: [id])
  applications    JobApplication[]
}

model JobApplication {
  id              String    @id @default(uuid())
  userId          String
  companyId       String
  jobId           String
  applicationData Json
  status          String    @default("pending")
  interview       String    @default("Not Interviewed")
  onboarding      String    @default("Not Onboarded")
  date            BigInt
  reviewedBy      String?
  reviewedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  company         Company   @relation(fields: [companyId], references: [id])
  job             Job       @relation(fields: [jobId], references: [id])
  admin           Admin?    @relation("AdminReviewer", fields: [reviewedBy], references: [id])
  user            User      @relation(fields: [userId], references: [id])
}

model UserProfile {
  id               String    @id @default(uuid())
  userId           String    @unique
  firstName        String?
  lastName         String?
  middleName       String?
  email            String    @unique
  phone            String?
  alternatePhone   String?
  dateOfBirth      DateTime?
  gender           String?
  maritalStatus    String?
  nationality      String    @default("Indian")
  fatherName       String?
  aadharNumber     String?
  address          Json?
  permanentAddress Json?
  education        Json?
  experience       Json?
  professional     Json?
  skills           Json?
  skillsDetailed   Json?
  languages        Json?
  documents        Json?
  socialLinks      Json?
  preferences      Json?
  resume           Json?
  profilePicture   String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @default(now()) @updatedAt
  user             User      @relation(fields: [userId], references: [id])
}

model Client {
  id             String              @id @default(uuid())
  company_name   String
  industry       String
  contact_person String
  email          String?
  phone          String?
  location       String?
  status         String              @default("active")
  isDeleted      Boolean             @default(false)
  deletedAt      DateTime?
  createdBy      String?
  updatedBy      String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  candidates     CRMCandidate[]
  jobs           CRMJob[]            @relation("ClientJobs")
  pipelines      CandidatePipeline[]
}

model CRMCandidate {
  id                 String              @id @default(uuid())
  name               String
  phone              String              @unique
  email              String?
  education          String?
  experience         String?
  state              String?
  district           String?
  trades             String?
  dob                String?
  gender             String?
  resume_url         String?
  status             String              @default("new_lead")
  source             String              @default("Direct")
  assigned_recruiter String?
  client_id          String?
  isDeleted          Boolean             @default(false)
  deletedAt          DateTime?
  createdBy          String?
  updatedBy          String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  aiScreening        AIScreening?
  client             Client?             @relation(fields: [client_id], references: [id])
  calls              Call[]
  pipelines          CandidatePipeline[]

  @@index([email])
  @@index([phone])
  @@index([assigned_recruiter])
  @@index([client_id])
  @@index([status])
}

model PipelineStage {
  id         String              @id @default(uuid())
  stage_name String              @unique
  order      Int                 @default(0)
  pipelines  CandidatePipeline[]
}

model CandidatePipeline {
  id           String        @id @default(uuid())
  candidate_id String
  client_id    String
  stage_id     String
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @default(now()) @updatedAt
  candidate    CRMCandidate  @relation(fields: [candidate_id], references: [id])
  client       Client        @relation(fields: [client_id], references: [id])
  stage        PipelineStage @relation(fields: [stage_id], references: [id])

  @@unique([candidate_id, client_id, stage_id])
}

model Call {
  id            String       @id @default(uuid())
  candidate_id  String
  recruiter_id  String
  duration      Int
  status        String
  recording_url String?
  notes         String?
  createdAt     DateTime     @default(now())
  candidate     CRMCandidate @relation(fields: [candidate_id], references: [id])
}

model AIScreening {
  id           String       @id @default(uuid())
  candidate_id String       @unique
  score        Int
  summary      String?
  skills       String?
  experience   String?
  status       String
  createdAt    DateTime     @default(now())
  candidate    CRMCandidate @relation(fields: [candidate_id], references: [id])
}

model CRMJob {
  id              String   @id @default(uuid())
  title           String
  client_id       String
  location        String?
  minSalary       String?
  maxSalary       String?
  minAge          Int?     @default(18)
  maxAge          Int?     @default(45)
  openPositions   Int      @default(1)
  filledPositions Int      @default(0)
  status          String   @default("open")
  postedDate      DateTime @default(now())
  requirements    String?
  education       String?
  specialization  String?
  minExperience   String?  @default("0")
  isDeleted       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  client          Client   @relation("ClientJobs", fields: [client_id], references: [id])

  @@index([client_id])
}

model ActivityLog {
  id         String   @id @default(uuid())
  action     String
  entityType String
  entityId   String?
  userId     String?
  details    String?
  createdAt  DateTime @default(now())
}
